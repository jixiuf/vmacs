From 5a62dfbf3eff18964bd24b8b5b7dd46ae527e4fb Mon Sep 17 00:00:00 2001
From: Anatolii Smolianinov <zarkonesmall@gmail.com>
Date: Mon, 23 Mar 2026 12:29:44 +0100
Subject: [PATCH] ForeignToplevelManagerV1 part for fcitx5 per-window input
 layout

Closes #1414

I've spent a couple of days on this code running and didn't find any problems
with per-window input switch, fcitx5 switches and remembers layouts
consistently.

I didn't test other fcitx5 functionality related to this protocol.
---
 river/Server.zig |  3 +++
 river/Window.zig | 26 ++++++++++++++++++++++++++
 2 files changed, 29 insertions(+)

diff --git a/river/Server.zig b/river/Server.zig
index fc5845d..2322af5 100644
--- a/river/Server.zig
+++ b/river/Server.zig
@@ -76,6 +76,7 @@ screencopy_manager: *wlr.ScreencopyManagerV1,
 image_copy_capture_manager: *wlr.ExtImageCopyCaptureManagerV1,
 output_image_capture_source_manager: *wlr.ExtOutputImageCaptureSourceManagerV1,
 
+foreign_toplevel_manager: *wlr.ForeignToplevelManagerV1,
 foreign_toplevel_list: *wlr.ExtForeignToplevelListV1,
 
 tearing_control_manager: *wlr.TearingControlManagerV1,
@@ -152,6 +153,7 @@ pub fn init(server: *Server, runtime_xwayland: bool) !void {
         .image_copy_capture_manager = try wlr.ExtImageCopyCaptureManagerV1.create(wl_server, 1),
         .output_image_capture_source_manager = try wlr.ExtOutputImageCaptureSourceManagerV1.create(wl_server, 1),
 
+        .foreign_toplevel_manager = try wlr.ForeignToplevelManagerV1.create(wl_server),
         .foreign_toplevel_list = try wlr.ExtForeignToplevelListV1.create(wl_server, 1),
 
         .tearing_control_manager = try wlr.TearingControlManagerV1.create(wl_server, 1),
@@ -340,6 +342,7 @@ fn blocklist(server: *Server, global: *const wl.Global) bool {
         global == server.screencopy_manager.global or
         global == server.image_copy_capture_manager.global or
         global == server.output_image_capture_source_manager.global or
+        global == server.foreign_toplevel_manager.global or
         global == server.foreign_toplevel_list.global or
         global == server.export_dmabuf_manager.global or
         global == server.data_control_manager.global or
diff --git a/river/Window.zig b/river/Window.zig
index ce1dbc6..a9905c2 100644
--- a/river/Window.zig
+++ b/river/Window.zig
@@ -263,6 +263,7 @@ rendering_requested: RenderingRequested = .init,
 box: wlr.Box = .{ .x = 0, .y = 0, .width = 0, .height = 0 },
 
 foreign_toplevel_handle: ?*wlr.ExtForeignToplevelHandleV1 = null,
+foreign_toplevel_v1_handle: ?*wlr.ForeignToplevelHandleV1 = null,
 
 pub fn create(impl: Impl) error{OutOfMemory}!*Window {
     assert(impl != .destroying);
@@ -422,6 +423,16 @@ pub fn manageStart(window: *Window) void {
                     }
                 }
 
+                if (window.foreign_toplevel_v1_handle == null) {
+                    if (wlr.ForeignToplevelHandleV1.create(server.foreign_toplevel_manager)) |handle| {
+                        window.foreign_toplevel_v1_handle = handle;
+                        if (window.getTitle()) |title| handle.setTitle(title);
+                        if (window.getAppId()) |app_id| handle.setAppId(app_id);
+                    } else |_| {
+                        log.err("failed to create foreign toplevel v1 handle", .{});
+                    }
+                }
+
                 break :blk window_v1;
             };
 
@@ -764,6 +775,10 @@ pub fn manageFinish(window: *Window) bool {
         break :blk false;
     };
 
+    if (window.foreign_toplevel_v1_handle) |handle| {
+        handle.setActivated(activated);
+    }
+
     const width, const height = blk: {
         if (wm_requested.fullscreen) |output| {
             const width, const height = output.sent.dimensions();
@@ -1146,6 +1161,11 @@ pub fn unmap(window: *Window) void {
         window.foreign_toplevel_handle = null;
     }
 
+    if (window.foreign_toplevel_v1_handle) |handle| {
+        handle.destroy();
+        window.foreign_toplevel_v1_handle = null;
+    }
+
     {
         var it = server.input_manager.seats.iterator(.forward);
         while (it.next()) |seat| {
@@ -1166,6 +1186,9 @@ pub fn notifyTitle(window: *Window) void {
             .app_id = window.getAppId(),
         });
     }
+    if (window.foreign_toplevel_v1_handle) |handle| {
+        if (window.getTitle()) |title| handle.setTitle(title);
+    }
 }
 
 pub fn notifyAppId(window: *Window) void {
@@ -1178,4 +1201,7 @@ pub fn notifyAppId(window: *Window) void {
             .app_id = window.getAppId(),
         });
     }
+    if (window.foreign_toplevel_v1_handle) |handle| {
+        if (window.getAppId()) |app_id| handle.setAppId(app_id);
+    }
 }
-- 
2.52.0

